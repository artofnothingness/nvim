" Faster Navigation
  noremap H ^
  noremap L $
  onoremap H ^
  onoremap L $
  xnoremap H ^
  xnoremap L g_

  noremap J 5j
  noremap K 5k
  noremap K 5k

  
  " Escape from instert
  inoremap jk <esc>
  inoremap kj <esc>

  nnoremap U J

" No Highlight after search
  nnoremap <silent> <BS> :let @/ = ''<Enter>

