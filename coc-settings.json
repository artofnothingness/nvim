{
  "clangd.enabled": true,
  "clangd.fallbackFlags": [
    "-std=c++2x",
    "-I/usr/include",
    "-I/opt/ros/melodic/include"
  ],
  "snippets.userSnippetsDirectory": "~/.config/nvim/plug-data/snippets",
  // python config
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,
  "snippets.ultisnips.directories": [
    "UltiSnips",
    "~/.config/nvim/plug-data/utils/snippets",
    "~/.config/nvim/autoload/plugged/vim-snippets/UltiSnips"
  ],
  // coc-explorer
  "explorer.width": 50,
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "explorer.keyMappings.global": {
    "<cr>": [
      "expandable?",
      "expand",
      "open"
    ],
    "v": "open:vsplit"
  },
  "languageserver": {
    "bash": {
      "command": "bash-language-server",
      "args": [
        "start"
      ],
      "filetypes": [
        "sh"
      ],
      "ignoredRootPaths": [
        "~"
      ]
    }
  },
  "diagnostic.errorSign": " ",
  "diagnostic.warningSign": " ",
  "diagnostic.infoSign": "",
  "diagnostic.hintSign": " ",
  "diagnostic.virtualText": true, // this won't work with codelens when error on same line
  "list.indicator": ">",
  "list.selectedSignText": " ",
  "suggest.completionItemKindLabels": {
    "text": "t",
    "method": "m",
    "function": ""
  }
}
